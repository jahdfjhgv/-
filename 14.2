#Задание 2. Разработать программу с применением пакета tk, взяв в качестве условия одну
#любую задачу из ПЗ №№ 1 – 9.



import tkinter as tk
from tkinter import messagebox


def calculate():
    try:
        a = float(entry_a.get())
        b = float(entry_b.get())

        result.config(text=f"Сумма: {a + b}")

    except ValueError:
        messagebox.showerror(
            "Ошибка",
            "Введите числа!"
        )


root = tk.Tk()
root.title("Сумма двух чисел")
root.geometry("300x250")

tk.Label(root, text="Первое число").pack(pady=5)

entry_a = tk.Entry(root)
entry_a.pack()

tk.Label(root, text="Второе число").pack(pady=5)

entry_b = tk.Entry(root)
entry_b.pack()

tk.Button(
    root,
    text="Вычислить",
    command=calculate
).pack(pady=15)

result = tk.Label(root, text="")
result.pack()

root.mainloop()
